{
  "mcpServers": {
    "azure": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@azure/mcp@latest", "server", "start"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT}"
      }
    }
  }
}
